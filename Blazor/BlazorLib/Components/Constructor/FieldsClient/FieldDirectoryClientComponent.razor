@inherits FieldComponentBaseModel

<MudSelect Disabled="@(SessionOfDocumentData is null)"
           T="EntryStandardModel"
           Label="@Field.Name"
           MultiSelection="@Field.IsMultiSelect"
           @bind-Value="DetectValue"
           @bind-SelectedValues="Options"
           HelperText="@Field.Hint"
           ToStringFunc="@converter"
           ReadOnly="IsBusyProgress">
    @if (DirectoryObject?.Childs.Any() == true)
    {
        @foreach (EntryStandardModel d in DirectoryObject.Childs)
        {
            <MudSelectItem T="EntryStandardModel" Value="@d">@d.Name</MudSelectItem>
        }
    }
</MudSelect>