@using MudBlazor
@using System.Globalization
@inherits BlazorBusyComponentBaseModel

<style>
    .links-for-files-messages i > u {
        cursor: pointer;
    }

    #tg-chats-table td.mud-table-cell {
        border-bottom: none;
    }
</style>
<HeadContent>
    <link rel="stylesheet" href="@Assets["chat-ui.css"]" />
</HeadContent>
<MudTable @ref="TableRef"
          ServerData="ServerReload"
          Dense Hover
          Loading="IsBusyProgress"
          id="tg-chats-table">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Сообщения (Telegram)</MudText>
        <MudSpacer />
        <MudTextField Immediate
                      @bind-Value="SearchStringQuery"
                      Placeholder="Поиск по тексту"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium"
                      Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>
            <MudTableSortLabel InitialDirection="SortDirection.Descending"
                               SortLabel="@(nameof(MessageTelegramStandardModel.CreatedAtUtc))"
                               T="MessageTelegramStandardModel"></MudTableSortLabel>
        </MudTh>
        <MudTh></MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        @{
            DateTime _cdt = context.CreatedAtUtc.GetCustomTime();
        }
        <MudTd>
            @if (CurrentChat?.ChatTelegramId == context.From?.UserTelegramId)
            {
                <div class="d-flex flex-row justify-content-start">
                    <MudAvatar Color="Color.Info" Variant="Variant.Outlined">M</MudAvatar>
                    <div>
                        <p class="small ms-3 mb-0 rounded-3 text-muted">
                            @context.From?.GetName()
                        </p>
                        <p class="small p-2 ms-3 mb-1 rounded-3 bg-body-tertiary">
                            @context.Text
                        </p>
                        <p class="small ms-3 mb-3 rounded-3 text-muted">
                            @($"{_cdt.ToString("d", GlobalStaticConstants.RU)} {@_cdt.ToString("t", GlobalStaticConstants.RU)}")
                        </p>
                    </div>
                </div>
            }
            else
            {
                <div class="d-flex flex-row justify-content-end pt-1">
                    <div>
                        <p class="small me-3 mb-0 rounded-3 text-muted d-flex justify-content-end">
                            @context.From?.GetName()
                        </p>
                        <p class="small p-2 me-3 mb-1 text-white rounded-3 bg-primary">
                            @context.Text
                        </p>
                        <p class="small me-3 mb-3 rounded-3 text-muted d-flex justify-content-end">
                            @($"{_cdt.ToString("d", GlobalStaticConstants.RU)} {@_cdt.ToString("t", GlobalStaticConstants.RU)}")
                        </p>
                    </div>
                    <MudAvatar Color="Color.Success" Variant="Variant.Outlined">U</MudAvatar>
                </div>
            }
        </MudTd>
        <MudTd>
            @context.Caption
            @if (context.Contact is not null)
            {
                <span class="badge text-bg-primary">
                    @context.Contact.FirstName |
                    @context.Contact.LastName |
                    @context.Contact.PhoneNumber |
                    @context.Contact.Vcard
                </span>
            }
        </MudTd>
        <MudTd>
            <FilesForMessageComponent Message="context" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>Сообщения не найдены</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Loading...</MudText>
    </LoadingContent>
    <PagerContent>
        <MudTablePager AllItemsText="Все сообщения" />
    </PagerContent>
</MudTable>