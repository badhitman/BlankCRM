		<PackageReference Include="MudBlazor" Version="9.5.0" />
		<PackageReference Include="Microsoft.AspNetCore.Components.QuickGrid" Version="10.0.9" />
		<PackageReference Include="TinyMCE.Blazor" Version="2.2.1" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\..\CodegeneratorLib\CodegeneratorLib.csproj" />
