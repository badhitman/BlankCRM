@using MudBlazor

@inherits BlazorBusyComponentBaseModel

<div class="input-group mb-3">
    <span class="input-group-text" title="@GetType().Name">Поиск адреса</span>
    <input @bind-value="FindText"
           @bind-value:event="oninput"
           type="text"
           class="form-control"
           placeholder="Искомое название"
           aria-label="с учётом регистра"
           aria-describedby="button-addon2" />
    <button @onclick="OpenDialogAsync" class="btn btn-outline-secondary" type="button" id="button-addon2" disabled="@(string.IsNullOrWhiteSpace(FindText))">Найти</button>
</div>
@code{
    [Inject]
    IDialogService DialogService { get; set; } = default!;


    string? FindText { get; set; }

    Task<IDialogReference> OpenDialogAsync()
    {
        DialogParameters<KladrFindDialogComponent> parameters = new()
        {
            { x => x.FindText, FindText }
        };

        DialogOptions options = new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Large, FullWidth = true };
        return DialogService.ShowAsync<KladrFindDialogComponent>("Поиск адреса", parameters, options);
    }
}