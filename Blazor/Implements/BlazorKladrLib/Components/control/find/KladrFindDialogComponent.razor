@using MudBlazor

@inherits BlazorBusyComponentBaseModel

<MudDialog>
    <TitleContent>
        Поиск: <span class="font-monospace">@FindText</span>
    </TitleContent>
    <DialogContent>
        <KladrFindTableResultComponent FindText="@(FindText)" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>
@code {
    /// <inheritdoc/>
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = default!;

    /// <inheritdoc/>
    [Parameter]
    public string? FindText { get; set; }


    private void Cancel() => MudDialog.Cancel();
}