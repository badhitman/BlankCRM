@using BlazorLib.Components.Shared.Layouts
@using BlankBlazorApp.Components.Layout
@using System.Globalization
@using System.Reflection
@using SharedLib

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentCulture.Parent.Name" data-bs-theme="@(IsDarkMode ? "dark" : "light")">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />

    <link rel="stylesheet" href="@Assets["lib/jquery-toast-plugin/jquery.toast.css"]" />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["BlankBlazorApp.styles.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />

    <ImportMap />

    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="@Assets["lib/bootstrap-icons/font/bootstrap-icons.min.css"]" />
    <link rel="stylesheet" href="@Assets["lib/highlight.js/styles/dark.min.css"]" />
    <link rel="stylesheet" href="@Assets["lib/jqueryui/jquery-ui.min.css"]" />
    <link rel="stylesheet" href="@Assets["js/ckeditor5/ckeditor5.css"]" />

    @if (WebConfig.Value.StylesInject is not null && WebConfig.Value.StylesInject.Length != 0)
    {
        foreach (InjectionBaseModel styleSrc in WebConfig.Value.StylesInject.Where(x => FilterLocalPathsForInject(x.LocalPathsForInject)))
        {
            if (styleSrc.Attributes is null || styleSrc.Attributes.Count == 0)
            {
                <link rel="stylesheet" href="@styleSrc.Src?version=@GlobalStaticConstants.InitSalt" />
            }
            else
            {
                <link rel="stylesheet" href="@styleSrc.Src?version=@GlobalStaticConstants.InitSalt" @attributes="styleSrc.Attributes" />
            }
        }
    }
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() { DOMContentLoaded(); });
    </script>
    
    <script src="@Assets["lib/jquery/jquery.min.js"]"></script>
    <script src="@Assets["lib/jqueryui/jquery-ui.min.js"]"></script>
    <script src="@Assets["lib/tinymce/tinymce.min.js"]"></script>
    <script src="@Assets["lib/jquery-toast-plugin/jquery.toast.js"]"></script>
    <script src="@Assets["lib/highlight.js/highlight.min.js"]"></script>
    <script src="@Assets["_content/MudBlazor/MudBlazor.min.js"]"></script>
    <script src="@Assets["js/scriptLoader.js"]"></script>
    <script src="@Assets["js/JsOfReCAPTCHA.js"]"></script>
    <script src="@Assets["firebase-messaging-sw.js"]"></script>

    <script src="https://www.gstatic.com/firebasejs/12.11.0/firebase-app.js" type="module"></script>
    <script src="https://www.gstatic.com/firebasejs/12.11.0/firebase-messaging.js" type="module"></script>
    <script src="@Assets["js/FirebaseSDK.js"]" type="module"></script>
    @if (_firebaseConf is not null)
    {
        <script type="module">
            if ('Notification' in window){
            window.FirebaseSDK.Initialize('@_firebaseConf.PublicMessagingToken');
            }
        </script>
    }
    
    <script src="@Assets["js/site.js"]"></script>
    <script src="@Assets["js/ckeditor5/ckeditor.js"]"></script>
    <script src="@Assets["js/CKEditorInterop.js"]"></script>

    @* <script src="https://www.google.com/recaptcha/api.js" async defer></script> *@
    @if (_includeTelegramBotWebAppScript)
    {
        <script src="https://telegram.org/js/telegram-web-app.js"></script>
    }
    <script>
        window.onBlazorReady = () => { $(document).tooltip({ track: true }); };
        window.tooltipeHide = () => { $("div.ui-tooltip").hide(); };
    </script>
    
    <div id="components-reconnect-modal">
        Возникла проблема со связью!
        (Текущая попытка пере-подключения:
        <span id="components-reconnect-current-attempt"></span> /
        <span id="components-reconnect-max-retries"></span>)
    </div>
    @if (WebConfig.Value.ScriptsInject is not null && WebConfig.Value.ScriptsInject.Length != 0)
    {
        foreach (InjectionBaseModel scriptSrc in WebConfig.Value.ScriptsInject.Where(x => FilterLocalPathsForInject(x.LocalPathsForInject)))
        {
            if (scriptSrc.Attributes is null || scriptSrc.Attributes.Count == 0)
            {
                <script src="@scriptSrc.Src"></script>
            }
            else
            {
                <script src="@scriptSrc.Src" @attributes="scriptSrc.Attributes"></script>
            }
        }
    }
</body>
</html>