@page "/outers-page"

@using BlazorOutersLib.Components.Breez
@using BlazorOutersLib.Components.Daichi
@using BlazorOutersLib.Components.Haier
@using BlazorOutersLib.Components.Rusklimat
@using MudBlazor
@using Microsoft.AspNetCore.Authorization
@using SharedLib

@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Roles = $"{GlobalStaticConstantsRoles.Roles.Admin},{GlobalStaticConstantsRoles.Roles.Debug}")]

<MudTabs Elevation="2" Rounded ApplyEffectsToContainer TabPanelsClass="pa-1">
    <MudTabPanel Text="Breez">
        <BreezManageComponent />
    </MudTabPanel>
    <MudTabPanel Text="Daichi">
        <DaichiManageComponent />
    </MudTabPanel>
    <MudTabPanel Text="Rusklimat">
        <RusklimatManageComponent />
    </MudTabPanel>
    <MudTabPanel Text="Haier">
        <HaierManageComponent />
    </MudTabPanel>
</MudTabs>