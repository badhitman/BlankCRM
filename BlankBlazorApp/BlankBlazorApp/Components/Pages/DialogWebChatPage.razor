@page "/web-chats/room-{DialogId:int}"

@using BlazorLib.Components.Chat
@using Microsoft.AspNetCore.Authorization
@using SharedLib

@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Roles = $"{GlobalStaticConstantsRoles.Roles.WebChatManage},{GlobalStaticConstantsRoles.Roles.HelpDeskChatsManage},{GlobalStaticConstantsRoles.Roles.Admin}")]

<DialogWebChatCardComponent DialogId="DialogId" />

@code {
    [Parameter]
    public int DialogId { get; set; }
}