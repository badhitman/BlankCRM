[Unit]
Description=firebase.app.stage.service

[Service]
WorkingDirectory=/srv/services.stage/FirebaseService
ExecStart=/usr/bin/dotnet /srv/services.stage/FirebaseService/FirebaseService.dll
Restart=always
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=dotnet-firebase-app.stage
User=www-data
Environment=DOTNET_ENVIRONMENT=Staging
Environment=DOTNET_PRINT_TELEMETRY_MESSAGE=false
Environment=TransmissionQueueNamePrefix=_stage

[Install]
WantedBy=multi-user.target