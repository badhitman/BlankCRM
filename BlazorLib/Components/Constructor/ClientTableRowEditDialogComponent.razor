@using BlazorLib.Components.Constructor.FieldsClient
@inherits BlazorBusyComponentBaseModel

<MudDialog>
    <DialogContent>
        @if (IsBusyProgress)
        {
            <div class="text-center">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            <ClientStandardViewFormComponent Form="PageJoinForm.Form"
                                             RowNum="RowNum"
                                             PageJoinForm="PageJoinForm" 
                                             SessionOfDocumentData="SessionOfDocumentData" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@IsBusyProgress" Color="Color.Primary" OnClick="Close">@(IsBusyProgress ? "Отправка данных..." : "Применить")</MudButton>
    </DialogActions>
</MudDialog>