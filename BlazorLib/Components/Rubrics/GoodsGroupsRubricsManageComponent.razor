@using static SharedLib.GlobalStaticConstantsRoutes
@using BlazorLib.Components.Constructor.DirectoriesCatalog
@using BlazorLib.Components.Rubrics.Properties
@using Microsoft.Extensions.Options
@using MudBlazor

@inherits BlazorBusyComponentBaseAuthModel

@{
    IQueryable<string>? _q = CommerceConf.Value.NomenclaturesRubricsPrefixes?
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .AsQueryable();
}

@if (IsBusyProgress)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate Class="my-3" />
}
else if (_q?.Any() != true)
{
    <MudTabs Elevation="2" Rounded ApplyEffectsToContainer>
        <MudTabPanel Text="Группы">
            <RubricsManageComponent TEntity="RubricNodeBodyNomenclatureConfigComponent"
                                    ProjectId="currentProjectId"
                                    ContextName="@($"{Routes.GOODS_CONTROLLER_NAME}-{Routes.CATEGORIES_CONTROLLER_NAME}")" />
        </MudTabPanel>
        <MudTabPanel Text="Поля" Disabled="@(IsBusyProgress || currentProjectId < 1)">
            <RubricFieldsManageComponent ProjectId="currentProjectId" />
        </MudTabPanel>
        <MudTabPanel Text="Списки" Disabled="@(IsBusyProgress || currentProjectId < 1)">
            <DirectoryViewComponent ProjectId="currentProjectId" ReloadHandler="ReloadAction" />
        </MudTabPanel>
    </MudTabs>
}
else
{
    <MudTabs Outlined Position="@Position.Left" Rounded Border ApplyEffectsToContainer @bind-ActivePanelIndex="ActiveIndex" @ref="panelRef" Style="width:100%">
        <MudTabPanel Text="По умолчанию" Style="width: 100%;">
            <MudTabs Elevation="2" Rounded ApplyEffectsToContainer>
                <MudTabPanel Text="Группы">
                    <RubricsManageComponent TEntity="RubricNodeBodyNomenclatureConfigComponent"
                                            ProjectId="currentProjectId"
                                            ContextName="@($"{Routes.GOODS_CONTROLLER_NAME}-{Routes.CATEGORIES_CONTROLLER_NAME}")" />
                </MudTabPanel>
                <MudTabPanel Text="Поля (default)" Disabled="@(IsBusyProgress || currentProjectId < 1)">
                    <RubricFieldsManageComponent ProjectId="currentProjectId" />
                </MudTabPanel>
                <MudTabPanel Text="Списки (default)" Disabled="@(IsBusyProgress || currentProjectId < 1)">
                    <DirectoryViewComponent ProjectId="currentProjectId" ReloadHandler="ReloadAction" />
                </MudTabPanel>
            </MudTabs>
        </MudTabPanel>
        @foreach (string _prefixName in _q)
        {
            <MudTabPanel Text="@_prefixName" ID="_prefixName" Style="width:100%">
                <MudTabs Elevation="2" Rounded ApplyEffectsToContainer>
                    <MudTabPanel Text="Группы">
                        <RubricsManageComponent TEntity="RubricNodeBodyNomenclatureConfigComponent"
                                                ProjectId="currentProjectId"
                                                PrefixName="@_prefixName"
                                                ContextName="@($"{Routes.GOODS_CONTROLLER_NAME}-{Routes.CATEGORIES_CONTROLLER_NAME}")" />
                    </MudTabPanel>
                    <MudTabPanel Text="@($"Поля (*{_prefixName} default)")" Disabled="@(IsBusyProgress || currentProjectId < 1)">
                        <RubricFieldsManageComponent ProjectId="currentProjectId" />
                    </MudTabPanel>
                    <MudTabPanel Text="@($"Списки (*{_prefixName} default)")" Disabled="@(IsBusyProgress || currentProjectId < 1)">
                        <DirectoryViewComponent ProjectId="currentProjectId" ReloadHandler="ReloadAction" />
                    </MudTabPanel>
                </MudTabs>
            </MudTabPanel>
        }
    </MudTabs>
}

@code {
    [Inject]
    IOptions<CommerceConfigModel> CommerceConf { get; set; } = default!;

    [Inject]
    IConstructorTransmission ConRepo { get; set; } = default!;


    int currentProjectId;
    MudTabs? panelRef;
    string? activePrefixName;
    int _activeIndex;
    int ActiveIndex
    {
        get => _activeIndex;
        set
        {
            _activeIndex = value;
            activePrefixName = panelRef?.ActivePanel?.ID?.ToString();
            InvokeAsync(ReadProject);
        }
    }

    async Task ReadProject()
    {
        if (CurrentUserSession is null)
        {
            SnackBarRepo.Error("CurrentUserSession is null");
            return;
        }

        await SetBusyAsync();
        TResponseModel<MainProjectViewModel> res = await ConRepo.GetCurrentMainProjectAsync(new()
        {
            UserIdentityId = CurrentUserSession.UserId,
            ContextName = GlobalStaticConstantsTransmission.GoodsCategoriesFieldsSetContextName(activePrefixName)
        });
        SnackBarRepo.ShowMessagesResponse(res.Messages);
        currentProjectId = res.Response?.Id ?? 0;
        await SetBusyAsync(false);
    }

    protected override async Task OnInitializedAsync()
    {
        await SetBusyAsync();
        await base.OnInitializedAsync();
        await ReadProject();
        await SetBusyAsync(false);
    }

    void ReloadAction()
    {

    }
}