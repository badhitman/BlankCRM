@using static SharedLib.GlobalStaticConstantsRoutes
@using BlazorLib.Components.Rubrics.Properties
@using Microsoft.Extensions.Options
@using MudBlazor

@{
    IQueryable<string>? _q = CommerceConf.Value.NomenclaturesRubricsPrefixes?
    .Where(x => !string.IsNullOrWhiteSpace(x))
    .AsQueryable();
}

@if (_q?.Any() != true)
{
    <MudTabs Elevation="2" Rounded ApplyEffectsToContainer>
        <MudTabPanel Text="Группы">
            <RubricsManageComponent TEntity="RubricNodeBodyNomenclatureConfigComponent"
                                    ContextName="@($"{Routes.GOODS_CONTROLLER_NAME}-{Routes.CATEGORIES_CONTROLLER_NAME}")" />
        </MudTabPanel>
        <MudTabPanel Text="Поля">
            <RubricFieldsManageComponent ContextName="@GlobalStaticConstantsTransmission.GoodsCategoriesFieldsSetContextName()" />
        </MudTabPanel>
        <MudTabPanel Text="Списки">
            <RubricDictionariesManageComponent ContextName="@GlobalStaticConstantsTransmission.GoodsCategoriesPropertiesConfigurationContextName()" />
        </MudTabPanel>
    </MudTabs>
}
else
{
    <MudTabs Outlined Position="@Position.Left" Rounded Border ApplyEffectsToContainer @bind-ActivePanelIndex="ActiveIndex" @ref="panelRef" Style="width:100%">
        <MudTabPanel Text="По умолчанию" Style="width: 100%;">
            <MudTabs Elevation="2" Rounded ApplyEffectsToContainer>
                <MudTabPanel Text="Группы">
                    <RubricsManageComponent TEntity="RubricNodeBodyNomenclatureConfigComponent"
                                            ContextName="@($"{Routes.GOODS_CONTROLLER_NAME}-{Routes.CATEGORIES_CONTROLLER_NAME}")" />
                </MudTabPanel>
                <MudTabPanel Text="Поля">
                    <RubricFieldsManageComponent ContextName="@GlobalStaticConstantsTransmission.GoodsCategoriesFieldsSetContextName()" />
                </MudTabPanel>
                <MudTabPanel Text="Списки">
                    <RubricDictionariesManageComponent ContextName="@GlobalStaticConstantsTransmission.GoodsCategoriesPropertiesConfigurationContextName()" />
                </MudTabPanel>
            </MudTabs>
        </MudTabPanel>
        @foreach (string _prefixName in _q)
        {
            <MudTabPanel Text="@_prefixName" ID="_prefixName" Style="width:100%">
                <MudTabs Elevation="2" Rounded ApplyEffectsToContainer>
                    <MudTabPanel Text="Группы">
                        <RubricsManageComponent TEntity="RubricNodeBodyNomenclatureConfigComponent"
                                                PrefixName="@_prefixName"
                                                ContextName="@($"{Routes.GOODS_CONTROLLER_NAME}-{Routes.CATEGORIES_CONTROLLER_NAME}")" />
                    </MudTabPanel>
                    <MudTabPanel Text="Поля">
                        <RubricFieldsManageComponent ContextName="@GlobalStaticConstantsTransmission.GoodsCategoriesFieldsSetContextName(_prefixName)" />
                    </MudTabPanel>
                    <MudTabPanel Text="Списки">
                        <RubricDictionariesManageComponent ContextName="@GlobalStaticConstantsTransmission.GoodsCategoriesPropertiesConfigurationContextName(_prefixName)" />
                    </MudTabPanel>
                </MudTabs>
            </MudTabPanel>
        }
    </MudTabs>
}

@code {
    [Inject]
    IOptions<CommerceConfigModel> CommerceConf { get; set; } = default!;


    MudTabs? panelRef;
    string? activePrefixName;
    int _activeIndex;
    int ActiveIndex
    {
        get => _activeIndex;
        set
        {
            _activeIndex = value;
            activePrefixName = panelRef?.ActivePanel?.ID?.ToString();
        }
    }
}