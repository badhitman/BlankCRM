@using MudBlazor

@inherits BlazorBusyComponentUsersCachedModel

@if (IsBusyProgress)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate />
}
<div class="my-3">
    <label for="exampleFormControlTextarea1" class="form-label">Отправка сообщения (web-chat)</label>
    <div class="input-group">
        <button @onclick="SendMessage"
                disabled="@CanNotSendMessage"
                class="btn btn-outline-@(string.IsNullOrWhiteSpace(_textSendMessage) ? "secondary" : "success") bi bi-send"
                type="button"></button>
        <textarea readonly="@IsBusyProgress"
                  @bind:event="oninput"
                  @bind="_textSendMessage"
                  class="form-control"
                  aria-label="With textarea"
                  id="exampleFormControlTextarea1"></textarea>
    </div>
</div>

<div class="input-group mb-3">
    <InputFile @key=@(_inputFileId) class="form-control" OnChange="SelectFilesChange" />
</div>

@if (loadedFiles.Count != 0)
{
    <ol class="list-group list-group-numbered mb-2">
        @foreach (IBrowserFile file_element in loadedFiles)
        {
            <li class="list-group-item d-flex justify-content-between align-items-start">
                <div class="ms-2 me-auto">
                    <div class="fw-bold">@file_element.Name</div>
                    @GlobalToolsStandard.SizeDataAsString(file_element.Size)
                </div>
                <span class="badge text-bg-primary rounded-pill">@file_element.LastModified</span>
            </li>
        }
    </ol>
    <div class="d-grid gap-2 mb-3">
        <button @onclick="() => { loadedFiles.Clear(); _inputFileId = Guid.NewGuid().ToString(); }"
                class="btn btn-outline-primary"
                type="button">
            Отмена
        </button>
    </div>
}
<MudTable ServerData="ServerReload" Dense Hover @ref="tableRef">
    <ToolBarContent>
        <MudText Typo="Typo.h6">
            Переписка
            @if (IsBusyProgress)
            {
                <sup class="spinner-grow spinner-grow-sm ms-2" role="status">
                    <span class="visually-hidden">Loading...</span>
                </sup>
            }
            else
            {
                <sup class="bi bi-arrow-clockwise ms-2"
                     style="cursor:pointer;"
                     title="Обновить таблицу"
                     @onclick="async () => { if (tableRef is not null) await tableRef.ReloadServerData(); }"></sup>
            }
        </MudText>
        <MudSpacer />
    </ToolBarContent>
    <HeaderContent>
        <MudTh>#</MudTh>
    </HeaderContent>
    <RowTemplate>
        @{
            DateTime _cdt = context.CreatedAtUTC.GetCustomTime();
        }
        <MudTd DataLabel="#">
            @if (context.SenderUserIdentityId == GlobalStaticConstantsRoles.Roles.System)
            {
                <figure class="text-center">
                    <blockquote class="blockquote">
                        @context.Text
                    </blockquote>
                    <figcaption class="blockquote-footer">
                        уведомление <cite title="система оповещения">system</cite> | @($"{_cdt.ToString("d", GlobalStaticConstants.RU)} {@_cdt.ToString("t", GlobalStaticConstants.RU)}")
                    </figcaption>
                </figure>
            }
            else
            {
                if (context.InitiatorMessageSender)
                {
                    <div class="d-flex flex-row justify-content-start">
                        <MudAvatar Color="Color.Info" Variant="Variant.Outlined">M</MudAvatar>
                        <div>
                            <p class="small ms-3 mb-0 rounded-3 text-muted">
                                00 | @($"{_cdt.ToString("d", GlobalStaticConstants.RU)} {@_cdt.ToString("t", GlobalStaticConstants.RU)}")
                            </p>
                            <p class="small p-2 ms-3 mb-1 rounded-3 bg-body-tertiary">
                                @context.Text
                            </p>
                            @if (context.AttachesFiles is not null && context.AttachesFiles.Count != 0)
                            {
                                <p class="small me-3 mb-3 rounded-3 text-muted d-flex justify-content-end">
                                    Файлы:
                                    @foreach (AttachesMessageWebChatModelDB _fa in context.AttachesFiles)
                                    {
                                        <a class="ms-2 link-primary"
                                               href="@_fa.GetURI()">
                                            @_fa.FileAttachName ( @GlobalToolsStandard.SizeDataAsString(_fa.FileLength) )
                                        </a>
                                    }
                                </p>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-row justify-content-end pt-1">
                        <div>
                            <p class="small me-3 mb-0 rounded-3 text-muted d-flex justify-content-end">
                                @(UsersCache.FirstOrDefault(x => x.UserId == context.SenderUserIdentityId)?.ToString() ?? context.SenderUserIdentityId)) | @($"{_cdt.ToString("d", GlobalStaticConstants.RU)} {@_cdt.ToString("t", GlobalStaticConstants.RU)}")
                            </p>
                            <p class="small p-2 me-3 mb-1 text-white rounded-3 bg-primary">
                                @context.Text
                            </p>
                            @if (context.AttachesFiles is not null && context.AttachesFiles.Count != 0)
                            {
                                <p class="small me-3 mb-3 rounded-3 text-muted d-flex justify-content-end">
                                    Файлы:
                                    @foreach (AttachesMessageWebChatModelDB _fa in context.AttachesFiles)
                                    {
                                        <a class="ms-2 link-primary"
                                               href="@_fa.GetURI()">
                                            @_fa.FileAttachName ( @GlobalToolsStandard.SizeDataAsString(_fa.FileLength) )
                                        </a>
                                    }
                                </p>
                            }
                        </div>
                        <MudAvatar Color="Color.Success" Variant="Variant.Outlined">U</MudAvatar>
                    </div>
                }
            }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>Сообщений нет</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Loading...</MudText>
    </LoadingContent>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>
<audio id="audioPlayerMessagesForWebChatComponent">
    <source src="/sounds/siri-answering.mp3" type="audio/mpeg" />
    Your browser does not support the audio tag.
</audio>