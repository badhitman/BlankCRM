@using Microsoft.AspNetCore.Components.Web.Virtualization
@using MudBlazor

@inherits BlazorBusyComponentUsersCachedModel

<span @onclick="ShowToggle" class="nav-link position-relative" style="cursor:pointer;">
    Чат
    @if (missingMessages > 0)
    {
        <span id="missingMessagesBadge" title="У вас есть не прочтённые сообщения" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
            @(missingMessages > 99 ? "99+" : missingMessages.ToString())
            <span class="visually-hidden">unread messages</span>
        </span>
    }
</span>
@if (ChatDialogOpen && dialogSessionEdit is not null && dialogSession is not null)
{
    <div class="offcanvas offcanvas-end show"
         data-bs-scroll="true"
         data-bs-backdrop="false"
         tabindex="-1"
         id="offcanvasScrolling"
         aria-labelledby="offcanvasScrollingLabel">
        <div class="offcanvas-header" style="padding-bottom: 1px;">
            <h5 class="offcanvas-title" id="offcanvasScrollingLabel">Чат</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close" @onclick="ShowToggle"></button>
        </div>
        <div class="offcanvas-body" style="padding-top: unset;">
            <div class="ma-2">
                @if (IsBusyProgress)
                {
                    <MudProgressLinear Color="Color.Primary" Indeterminate />
                }
                @if (string.IsNullOrWhiteSpace(dialogSession.InitiatorHumanName) && string.IsNullOrWhiteSpace(dialogSession.InitiatorIdentityId))
                {
                    <div class="alert alert-warning" role="alert">
                        <label for="exampleFormControlText1" class="form-label">Как к Вам обращаться?</label>
                        <div class="input-group">
                            <input type="text"
                                   readonly="@IsBusyProgress"
                                   @bind:event="oninput"
                                   @bind="dialogSessionEdit.InitiatorHumanName"
                                   class="form-control"
                                   id="exampleFormControlText1" />
                            <button @onclick="SevaDialog"
                                    disabled="@string.IsNullOrWhiteSpace(dialogSessionEdit.InitiatorHumanName)"
                                    class="btn btn-outline-@(string.IsNullOrWhiteSpace(_textSendMessage) ? "secondary" : "success") bi bi-check-circle"
                                    type="button"></button>
                        </div>
                    </div>
                }
                else
                {
                    <label for="exampleFormControlTextarea1" class="form-label">Отправка сообщения (поддержка)</label>
                    <div class="input-group">
                        <textarea readonly="@IsBusyProgress"
                                  @onkeydown="OnKeyPresHandler"
                                  @bind:event="oninput"
                                  @bind="_textSendMessage"
                                  class="form-control"
                                  id="exampleFormControlTextarea1"
                                  rows="1"></textarea>
                        <button @onclick="SendMessage"
                                disabled="@CannotSendMessage"
                                class="btn btn-outline-@(string.IsNullOrWhiteSpace(_textSendMessage) ? "secondary" : "success") bi bi-send"
                                type="button"></button>
                    </div>
                    <div class="form-text">
                        @dialogSession.InitiatorHumanName
                        @(string.IsNullOrWhiteSpace(dialogSession.InitiatorContacts) ? "" : $" ({dialogSession.InitiatorContacts})")
                    </div>
                }
            </div>
            <hr />
            @if (string.IsNullOrWhiteSpace(dialogSession.InitiatorHumanName) && string.IsNullOrWhiteSpace(dialogSession.InitiatorIdentityId))
            {
                <figure class="text-center">
                    <blockquote class="blockquote">
                        <p>Представьтесь</p>
                    </blockquote>
                    <figcaption class="blockquote-footer">
                        Укажите ваше имя
                    </figcaption>
                </figure>
            }

            <Virtualize Context="message"
                        OverscanCount="@(virtualCacheSize / 2)"
                        ItemsProvider="LoadMessages"
                        @ref="virtualizeComponent">
                <ItemContent>
                    @{
                        DateTime _cdt = message.CreatedAtUTC.GetCustomTime();
                        UserInfoModel? senderUser = UsersCache.FirstOrDefault(x => x.UserId == message.SenderUserIdentityId);
                    }
                    @if (message.SenderUserIdentityId == GlobalStaticConstantsRoles.Roles.System)
                    {
                        <figure class="text-center">
                            <blockquote class="blockquote">
                                @message.Text
                            </blockquote>
                            <figcaption class="blockquote-footer">
                                уведомление <cite title="система оповещения">system</cite> | @($"{_cdt.ToString("d", GlobalStaticConstants.RU)} {@_cdt.ToString("t", GlobalStaticConstants.RU)}")
                            </figcaption>
                        </figure>
                    }
                    else
                    {
                        if (message.InitiatorMessageSender)
                        {
                            <div class="d-flex flex-row justify-content-start">
                                <MudAvatar Color="Color.Info" Variant="Variant.Outlined">M</MudAvatar>
                                <div>
                                    <p class="small ms-3 mb-0 rounded-3 text-muted">
                                        00 | @($"{_cdt.ToString("d", GlobalStaticConstants.RU)} {@_cdt.ToString("t", GlobalStaticConstants.RU)}")
                                    </p>
                                    <p class="small p-2 ms-3 mb-1 rounded-3 bg-body-tertiary">
                                        @message.Text
                                    </p>
                                    @if (message.AttachesFiles is not null && message.AttachesFiles.Count != 0)
                                    {
                                        <p class="small me-3 mb-3 rounded-3 text-muted d-flex justify-content-end">
                                            Файлы:
                                            @foreach (AttachesMessageWebChatModelDB _fa in message.AttachesFiles)
                                            {
                                                <a class="ms-2 link-primary"
                                                       href="@_fa.GetURI()">
                                                    @_fa.FileAttachName ( @GlobalToolsStandard.SizeDataAsString(_fa.FileLength) )
                                                </a>
                                            }
                                        </p>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex flex-row justify-content-end pt-1">
                                <div>
                                    <p class="small me-3 mb-0 rounded-3 text-muted d-flex justify-content-end">
                                        @(UsersCache.FirstOrDefault(x => x.UserId == message.SenderUserIdentityId)?.ToString() ?? message.SenderUserIdentityId)) | @($"{_cdt.ToString("d", GlobalStaticConstants.RU)} {@_cdt.ToString("t", GlobalStaticConstants.RU)}")
                                    </p>
                                    <p class="small p-2 me-3 mb-1 text-white rounded-3 bg-primary">
                                        @message.Text
                                    </p>
                                    @if (message.AttachesFiles is not null && message.AttachesFiles.Count != 0)
                                    {
                                        <p class="small me-3 mb-3 rounded-3 text-muted d-flex justify-content-end">
                                            Файлы:
                                            @foreach (AttachesMessageWebChatModelDB _fa in message.AttachesFiles)
                                            {
                                                <a class="ms-2 link-primary"
                                                       href="@_fa.GetURI()">
                                                    @_fa.FileAttachName ( @GlobalToolsStandard.SizeDataAsString(_fa.FileLength) )
                                                </a>
                                            }
                                        </p>
                                    }
                                </div>
                                <MudAvatar Color="Color.Success" Variant="Variant.Outlined">U</MudAvatar>
                            </div>
                        }
                    }
                </ItemContent>
                <Placeholder>
                    <p>
                        <MudProgressLinear Color="Color.Primary" Indeterminate Class="my-7" />
                    </p>
                </Placeholder>
                <EmptyContent>
                    <figure class="text-center">
                        <blockquote class="blockquote">
                            <p>Сообщений нет</p>
                        </blockquote>
                        @* <figcaption class="blockquote-footer">
                                Someone famous in <cite title="Source Title">Source Title</cite>
                            </figcaption> *@
                    </figure>
                </EmptyContent>
            </Virtualize>
        </div>
        @if (string.IsNullOrWhiteSpace(dialogSession.InitiatorContacts) && string.IsNullOrWhiteSpace(dialogSession.InitiatorIdentityId))
        {
            <div class="pa-2">
                <hr />
                <label for="exampleFormControlTextarea2" class="form-label">Контакты</label>
                <div class="input-group">
                    <textarea readonly="@IsBusyProgress"
                              @bind:event="oninput"
                              @bind="dialogSessionEdit.InitiatorContacts"
                              class="form-control"
                              id="exampleFormControlTextarea2"
                              rows="1"></textarea>
                    <button @onclick="SevaDialog"
                            disabled="@string.IsNullOrWhiteSpace(dialogSessionEdit.InitiatorContacts)"
                            class="btn btn-outline-@(string.IsNullOrWhiteSpace(_textSendMessage) ? "secondary" : "success") bi bi-check-square"
                            type="button"></button>
                </div>
                <div class="form-text">Email или телефон для обратной связи</div>
            </div>
        }
        @lock (UsersSessions)
        {
            if (UsersSessions.Count != 0)
            {
                <p class="pa-2">
                    Операторы <sup>(online)</sup>:
                    @foreach (PongClientsWebChatEventModel _userClient in UsersSessions.Where(x => !string.IsNullOrWhiteSpace(x.CurrentUserSession?.UserName)).DistinctBy(x => x.CurrentUserSession!.UserName))
                    {
                        <span class="badge text-bg-light">@_userClient.CurrentUserSession!.UserName</span>
                    }
                </p>
            }
        }
    </div>
}
<audio id="audioPlayerChatWrapperComponent">
    <source src="@(ChatDialogOpen ? "/sounds/oh-oh-icq-sound.mp3" : "/sounds/airdrop.mp3")" type="audio/mpeg" />
    Your browser does not support the audio tag.
</audio>